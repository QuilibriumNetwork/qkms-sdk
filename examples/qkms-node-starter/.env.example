# QNZM credentials (mint these via the QNZM-aware service / qnzm-auth bridge)
QKMS_APP_ID=AKIAEXAMPLE
QKMS_APP_SECRET=secret-example

# QKMS server URL
QKMS_SERVER=https://qkms.quilibrium.com

# Where to persist sidecar identity + key shares
QKMS_DATA_DIR=./qkms-sdk-data

# Treasury wallet (set after running create_wallet once)
TREASURY_WALLET_ID=
TREASURY_WALLET_ADDRESS=
TREASURY_OWNER_ID=

# 2-of-2 quorum partner (a sidecar id or QNZM access key)
TREASURY_QUORUM_PUBLIC_KEY=

# Optional: Base Sepolia RPC URL
BASE_SEPOLIA_RPC=https://sepolia.base.org

# Server port
PORT=3300
