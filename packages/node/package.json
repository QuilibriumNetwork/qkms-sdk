{
  "name": "@quilibrium/qkms-sdk-node",
  "version": "0.1.0",
  "description": "Node.js server SDK for qkms-sdk. Mirrors @privy-io/node resource API; backed by an in-process MPC sidecar with filesystem-persisted key shares.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "test": "echo 'no tests yet'"
  },
  "dependencies": {
    "@quilibrium/qkms-sdk-core": "workspace:*",
    "viem": "^2.37.5"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
